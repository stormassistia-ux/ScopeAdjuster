rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (enum: ['admin', 'user'])
    //
    // Collection: reports
    // Document ID: {reportId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - type: string (required)
    //   - title: string (required)
    //   - carrier: string
    //   - timestamp: number (required)
    //   - platform: string
    //   - insuredName: string
    //   - claimNumber: string
    //   - state: object
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "stormassistia@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidReport(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'title', 'timestamp']) &&
             data.id is string &&
             data.userId is string &&
             data.type in ['Investigation', 'Comparison', 'Reverse Engineer', 'Compliance Audit'] &&
             data.title is string &&
             data.timestamp is number;
    }

    function isValidBaseline(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'timestamp', 'lineItems']) &&
             data.id is string &&
             data.userId is string &&
             data.name is string &&
             data.timestamp is number &&
             data.lineItems is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidReport(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidReport(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /baselines/{baselineId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBaseline(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidBaseline(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
